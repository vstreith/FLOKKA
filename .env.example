# ─────────────────────────────────────────────────────────────
# Variables d'environnement FLOKKA
# Copier en `.env` pour le développement local.
# En production (Netlify), définir ces variables dans :
#   Site settings → Environment variables.
# ─────────────────────────────────────────────────────────────

# PostgreSQL — connexion runtime.
# En production Supabase : utiliser le "Connection pooler" (Transaction, port 6543)
#   postgresql://postgres.<ref>:<MOT_DE_PASSE>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@localhost:5432/flokka_dev?schema=public"

# PostgreSQL — connexion directe (port 5432), utilisée par les migrations Prisma.
# En production Supabase : "Direct connection"
#   postgresql://postgres.<ref>:<MOT_DE_PASSE>@aws-0-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://user:password@localhost:5432/flokka_dev?schema=public"

# Clé secrète pour signer les jetons JWT de l'admin (chaîne aléatoire longue).
JWT_SECRET="changez-moi-en-production"
