# ─────────────────────────────────────────────────────────────
# Variables d'environnement FLOKKA
# Copier en `.env` pour le développement local.
# En production (Vercel), définir ces variables dans :
#   Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# PostgreSQL — connexion runtime.
# En production Neon : utiliser l'endpoint POOLED (host avec "-pooler"), SSL requis.
#   postgresql://<user>:<password>@ep-xxxx-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/flokka_dev?schema=public"

# PostgreSQL — connexion directe (sans pooler), utilisée par les migrations Prisma.
# En production Neon : endpoint DIRECT (host SANS "-pooler"), SSL requis.
#   postgresql://<user>:<password>@ep-xxxx.<region>.aws.neon.tech/<db>?sslmode=require
DIRECT_URL="postgresql://user:password@localhost:5432/flokka_dev?schema=public"

# Clé secrète pour signer les jetons JWT de l'admin (chaîne aléatoire longue).
JWT_SECRET="changez-moi-en-production"
