# ─────────────────────────────────────────────────────────────
# Variables d'environnement FLOKKA
# Copier en `.env` pour le développement local.
# En production (Vercel), définir dans : Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# PostgreSQL — UNE seule chaîne de connexion suffit.
# Neon : utilisez l'endpoint direct (host SANS "-pooler") + ?sslmode=require
#   postgresql://<user>:<password>@ep-xxxx.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/flokka_dev?schema=public"

# Clé secrète pour signer les jetons JWT de l'admin (chaîne aléatoire longue).
JWT_SECRET="changez-moi-en-production"

# Optionnel — uniquement si vous passez DATABASE_URL sur l'endpoint POOLED de Neon
# (host avec "-pooler") : indiquez alors l'endpoint direct ici pour les migrations,
# et réactivez `directUrl = env("DIRECT_URL")` dans prisma/schema.prisma.
# DIRECT_URL="postgresql://<user>:<password>@ep-xxxx.<region>.aws.neon.tech/<db>?sslmode=require"
